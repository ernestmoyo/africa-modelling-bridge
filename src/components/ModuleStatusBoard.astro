---
import { getCollection } from 'astro:content';
import StatusPill from '@/components/StatusPill.astro';

type FamilyKey = 'data' | 'people' | 'ai' | 'ops';
type PhaseKey = 'v0_0' | 'v0_1' | 'v0_5' | 'v1_0' | 'v1_5';
type ChosenStatus =
  | 'live'
  | 'preview'
  | 'coming-v0_1'
  | 'coming-v0_5'
  | 'coming-v1_0'
  | 'coming-v1_5'
  | 'coming-v2_0';

interface ShipPhase {
  v0_0: string;
  v0_1?: string;
  v0_5?: string;
  v1_0?: string;
  v1_5?: string;
}

interface ModuleData {
  id: string;
  name: string;
  family: FamilyKey;
  surface: string;
  purpose: string;
  ship_phase: ShipPhase;
  is_live_in_v0_0: boolean;
  order: number;
}

const all = await getCollection('modules');
const modules = all
  .map((m) => ({ ...m, data: m.data as ModuleData }))
  .sort((a, b) => a.data.order - b.data.order);

function chooseStatus(m: ModuleData): ChosenStatus {
  if (m.is_live_in_v0_0) return 'live';
  for (const k of ['v0_1', 'v0_5', 'v1_0', 'v1_5'] as const) {
    if (m.ship_phase[k]) return `coming-${k}` as ChosenStatus;
  }
  return 'coming-v2_0';
}

const families: {
  key: FamilyKey;
  label: string;
  tagline: string;
  count: string;
  stripe: string;
  badge?: string;
}[] = [
  {
    key: 'data',
    label: 'Data spine',
    tagline: 'The information layer the rest of the platform stands on.',
    count: 'M1 – M6',
    stripe: 'bg-bridge-600',
  },
  {
    key: 'people',
    label: 'People',
    tagline: 'Researchers and funders made visible and routable.',
    count: 'M7 – M9',
    stripe: 'bg-ember-500',
  },
  {
    key: 'ai',
    label: 'AI-powered',
    tagline: 'Frontier models, applied in narrow loops with editor review.',
    count: 'M10 – M15',
    stripe: 'bg-bridge-700',
    badge: 'AI',
  },
  {
    key: 'ops',
    label: 'Operations',
    tagline: 'The governance, distribution and audit layer.',
    count: 'M16 – M20',
    stripe: 'bg-ink-600',
  },
];

const phaseOrder: PhaseKey[] = ['v0_0', 'v0_1', 'v0_5', 'v1_0', 'v1_5'];
const phaseLabel: Record<PhaseKey, string> = {
  v0_0: '0.0',
  v0_1: '0.1',
  v0_5: '0.5',
  v1_0: '1.0',
  v1_5: '1.5',
};

const totalLive = modules.filter((m) => m.data.is_live_in_v0_0).length;
const totalCount = modules.length;
---

<section aria-labelledby="module-status-board" class="not-prose">

  <!-- Board header -->
  <header class="mb-10 grid gap-8 lg:grid-cols-12 lg:items-end">
    <div class="lg:col-span-7">
      <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-bridge-600 mb-3">Live · build status</p>
      <h2 id="module-status-board" class="font-display text-3xl sm:text-4xl font-semibold tracking-tightest text-ink-900 text-balance">
        Twenty modules. One on, the rest still build.
      </h2>
      <p class="mt-5 text-base text-ink-600 leading-relaxed text-pretty max-w-readable">
        Each module has an owner, a surface, a budget and an on/off switch. A funder can sponsor a
        single module. If any module is turned off, the rest still build. This board is generated from
        the content collection — it is the same source of truth the team plans against.
      </p>
    </div>
    <div class="lg:col-span-5">
      <div class="grid grid-cols-3 gap-px overflow-hidden rounded-xl border border-bridge-100/60 bg-bridge-100/40">
        <div class="bg-cream-50 p-4">
          <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-bridge-600">Live in v0.0</p>
          <p class="mt-1 font-display text-2xl font-semibold text-ember-600">{totalLive}<span class="text-ink-200 text-base">/{totalCount}</span></p>
        </div>
        <div class="bg-cream-50 p-4">
          <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-bridge-600">Families</p>
          <p class="mt-1 font-display text-2xl font-semibold text-ink-900">4</p>
        </div>
        <div class="bg-cream-50 p-4">
          <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-bridge-600">Phases</p>
          <p class="mt-1 font-display text-2xl font-semibold text-ink-900">v0.0 → v1.5</p>
        </div>
      </div>
    </div>
  </header>

  <!-- Legend -->
  <div class="mb-12 flex flex-wrap items-center gap-x-6 gap-y-3 rounded-xl bg-cream-100/50 border border-bridge-100/40 px-5 py-3">
    <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-ink-400">Legend</span>
    <span class="inline-flex items-center gap-2 text-xs text-ink-600">
      <span class="inline-block h-2.5 w-3.5 rounded-sm bg-ember-500"></span> Shipped
    </span>
    <span class="inline-flex items-center gap-2 text-xs text-ink-600">
      <span class="inline-block h-2.5 w-3.5 rounded-sm bg-bridge-300"></span> In scope, not yet
    </span>
    <span class="inline-flex items-center gap-2 text-xs text-ink-600">
      <span class="inline-block h-2.5 w-3.5 rounded-sm bg-ink-100"></span> Out of scope at this phase
    </span>
  </div>

  <!-- Families -->
  <div class="space-y-16">
    {families.map((fam) => {
      const items = modules.filter((m) => m.data.family === fam.key);
      return (
        <div>
          <!-- Family header strip -->
          <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div class="flex items-center gap-4">
              <span class={`h-9 w-1.5 rounded-full ${fam.stripe}`} aria-hidden="true"></span>
              <div>
                <div class="flex items-center gap-3">
                  <h3 class="font-display text-2xl font-semibold tracking-snug text-ink-900">
                    {fam.label}
                  </h3>
                  {fam.badge && (
                    <span class="inline-flex items-center gap-1 rounded-md bg-bridge-700 px-2 py-0.5 font-mono text-[9px] uppercase tracking-[0.18em] text-cream-50">
                      <span class="h-1 w-1 rounded-full bg-ember-200"></span>
                      {fam.badge}
                    </span>
                  )}
                </div>
                <p class="text-sm text-ink-500 mt-0.5">{fam.tagline}</p>
              </div>
            </div>
            <div class="flex items-baseline gap-3 sm:pl-0 pl-5">
              <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-ink-400">Modules</span>
              <span class="font-mono text-sm text-ink-700">{fam.count}</span>
              <span class="font-mono text-xs text-ink-300">·</span>
              <span class="font-mono text-xs text-ink-500">{items.length} total</span>
            </div>
          </div>

          <!-- Grid -->
          <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {items.map((m) => {
              const d = m.data;
              const status = chooseStatus(d);
              const isFlagship = d.id === 'M10';

              return (
                <article
                  class:list={[
                    'group relative rounded-xl bg-cream-50 p-5 shadow-card transition hover:shadow-lift hover:-translate-y-0.5',
                    isFlagship
                      ? 'border-2 border-ember-500/60 sm:col-span-2 lg:col-span-2'
                      : 'border border-bridge-100/60',
                  ]}
                >
                  {isFlagship && (
                    <span class="absolute -top-2.5 left-5 inline-flex items-center gap-1.5 rounded-full bg-ember-500 px-2.5 py-0.5 font-mono text-[9px] uppercase tracking-[0.18em] text-cream-50 shadow-card">
                      <span class="h-1 w-1 rounded-full bg-cream-50 animate-pulse"></span>
                      Flagship · the magic moment
                    </span>
                  )}

                  <!-- Top row: ID + status -->
                  <div class="flex items-start justify-between gap-3">
                    <span class="font-mono text-xs font-medium tracking-wider text-bridge-600">
                      {d.id}
                    </span>
                    <StatusPill status={status} small={true} />
                  </div>

                  <!-- Name -->
                  <h4
                    class:list={[
                      'mt-3 font-display font-semibold tracking-snug text-ink-900 text-balance',
                      isFlagship ? 'text-xl' : 'text-lg',
                    ]}
                  >
                    {d.name}
                  </h4>

                  <!-- Surface -->
                  <p class="mt-1.5 font-mono text-[11px] text-bridge-500 truncate">
                    {d.surface}
                  </p>

                  <!-- Purpose -->
                  <p
                    class:list={[
                      'mt-3 text-sm text-ink-600 leading-relaxed text-pretty',
                      isFlagship ? 'line-clamp-3' : 'line-clamp-2',
                    ]}
                  >
                    {d.purpose}
                  </p>

                  <!-- Phase strip -->
                  <div class="mt-5 pt-4 border-t border-bridge-100/60">
                    <p class="font-mono text-[9px] uppercase tracking-[0.18em] text-ink-400 mb-2">
                      Ship phase
                    </p>
                    <div class="flex items-stretch gap-1">
                      {phaseOrder.map((phase, idx) => {
                        const text = d.ship_phase[phase];
                        const filled = Boolean(text);
                        const shipped = phase === 'v0_0' && d.is_live_in_v0_0;
                        const cellClass = shipped
                          ? 'bg-ember-500 text-cream-50 border-ember-500'
                          : filled
                          ? 'bg-bridge-50 text-bridge-700 border-bridge-200'
                          : 'bg-ink-50 text-ink-200 border-ink-100';
                        return (
                          <div
                            class:list={[
                              'flex-1 rounded-md border px-1.5 py-1.5 text-center transition-colors',
                              cellClass,
                            ]}
                            title={text || `Out of scope at v${phaseLabel[phase]}`}
                          >
                            <span class="block font-mono text-[9px] font-medium leading-none">
                              v{phaseLabel[phase]}
                            </span>
                            <span
                              class:list={[
                                'block mt-1 mx-auto h-1 w-1 rounded-full',
                                shipped
                                  ? 'bg-cream-50'
                                  : filled
                                  ? 'bg-bridge-500'
                                  : 'bg-ink-200',
                              ]}
                              aria-hidden="true"
                            ></span>
                          </div>
                        );
                      })}
                    </div>
                  </div>
                </article>
              );
            })}
          </div>
        </div>
      );
    })}
  </div>

  <!-- Footer note -->
  <p class="mt-12 text-xs text-ink-400 font-mono">
    Source · <span class="text-ink-600">src/content/modules/</span> · Updated on every public commit.
  </p>

</section>
