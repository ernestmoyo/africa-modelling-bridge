---
const nav = [
  { href: '/africa-modelling-bridge/approach', label: 'The movement' },
  { href: '/africa-modelling-bridge/researchers/ernest-moyo', label: 'Founder' },
  { href: '/africa-modelling-bridge/countries/tanzania', label: 'Countries' },
  { href: '/africa-modelling-bridge/dossiers', label: 'Dossiers' },
  { href: '/africa-modelling-bridge/tools/triage', label: 'Tools' },
  { href: '/africa-modelling-bridge/support', label: 'Get involved' },
  { href: '/africa-modelling-bridge/about', label: 'About' },
];
const path = Astro.url.pathname;
---

<header class="sticky top-0 z-40 border-b border-ink-100/60 bg-cream-50/85 backdrop-blur">
  <div class="container-wide flex h-16 items-center justify-between gap-6">
    <a href="/africa-modelling-bridge/" class="flex items-center gap-3 group" aria-label="Home">
      <span class="relative grid place-items-center h-9 w-9 rounded-md bg-bridge-600 text-cream-50 transition-transform group-hover:-rotate-3">
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 17c3-6 7-6 9-6s6 0 9 6" />
          <circle cx="6" cy="17" r="1.3" fill="currentColor" />
          <circle cx="18" cy="17" r="1.3" fill="currentColor" />
        </svg>
      </span>
      <span class="flex flex-col leading-tight">
        <span class="font-display text-base font-semibold tracking-snug text-ink-900">Africa Modelling Bridge</span>
        <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-bridge-600">a modelling movement</span>
      </span>
    </a>
    <nav class="hidden md:flex items-center gap-1" aria-label="Primary">
      {nav.map((item) => {
        const active = path === item.href || (item.href !== '/' && path.startsWith(item.href));
        return (
          <a
            href={item.href}
            class:list={[
              'rounded-md px-3 py-1.5 text-sm transition-colors',
              active
                ? 'text-bridge-700 bg-bridge-50'
                : 'text-ink-600 hover:text-bridge-700 hover:bg-bridge-50/60',
            ]}
          >
            {item.label}
          </a>
        );
      })}
    </nav>
    <a
      href="/africa-modelling-bridge/support"
      class="hidden lg:inline-flex items-center gap-2 rounded-md bg-ember-500 px-4 py-2 text-sm font-medium text-cream-50 shadow-card hover:bg-ember-600 hover:-translate-y-px transition"
    >
      <span class="h-1.5 w-1.5 rounded-full bg-cream-50/90 animate-pulse"></span>
      Get involved
    </a>
    <details class="md:hidden relative">
      <summary class="list-none cursor-pointer rounded-md p-2 text-ink-700 hover:bg-ink-100">
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16" stroke-linecap="round"/></svg>
      </summary>
      <div class="absolute right-0 mt-2 w-56 rounded-lg border border-ink-100 bg-cream-50 p-2 shadow-lift">
        {nav.map((item) => (
          <a href={item.href} class="block rounded-md px-3 py-2 text-sm text-ink-700 hover:bg-bridge-50">{item.label}</a>
        ))}
      </div>
    </details>
  </div>
</header>
