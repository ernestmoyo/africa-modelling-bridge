---
import StatusPill from '@/components/StatusPill.astro';

interface Feature {
  title: string;
  body: string;
}

interface Props {
  moduleId: string;
  name: string;
  status: 'coming-v0_1' | 'coming-v0_5' | 'coming-v1_0' | 'coming-v1_5' | 'coming-v2_0';
  shipPhase: string;
  headline: string;
  italic?: string;
  intro: string;
  features: Feature[];
  technicalLabel?: string;
  technicalNote?: string;
  cta?: { label: string; href: string };
}

const { moduleId, name, status, shipPhase, headline, italic, intro, features, technicalLabel, technicalNote, cta } =
  Astro.props;
---

<section class="relative overflow-hidden border-b border-bridge-100/50">
  <div class="grain-overlay"></div>
  <div class="container-wide py-16 sm:py-24 relative">
    <div class="flex items-center gap-3 mb-5">
      <span class="eyebrow">{moduleId} · {name.toUpperCase()}</span>
      <StatusPill status={status} />
    </div>
    <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-semibold tracking-tightest text-balance leading-[1.05]">
      {headline}
      {italic && <><br /><span class="italic text-bridge-700">{italic}</span></>}
    </h1>
    <p class="mt-6 max-w-2xl text-lg text-ink-600 leading-relaxed text-pretty">{intro}</p>
    <div class="mt-6 flex flex-wrap items-center gap-x-5 gap-y-2 text-xs font-mono uppercase tracking-[0.12em] text-ink-500">
      <span>Ships · {shipPhase}</span>
      {technicalLabel && <span>{technicalLabel}</span>}
      <span>Module · {moduleId}</span>
    </div>
  </div>
</section>

<section class="relative">
  <div class="container-wide py-16">
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {features.map((f) => (
        <div class="rounded-2xl border border-bridge-100 bg-cream-50 p-6 shadow-card hover:shadow-lift hover:-translate-y-px transition">
          <h3 class="font-display text-lg font-semibold text-ink-900 leading-snug">{f.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-600">{f.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

{technicalNote && (
  <section class="border-t border-bridge-100/60 bg-bridge-50/40">
    <div class="container-page py-12">
      <div class="rounded-2xl border border-bridge-100 bg-cream-50 p-6 sm:p-8">
        <div class="eyebrow">UNDER THE HOOD · COMING {shipPhase.toUpperCase()}</div>
        <p class="mt-3 text-ink-700 leading-relaxed">{technicalNote}</p>
      </div>
    </div>
  </section>
)}

<section class="border-t border-bridge-100/60">
  <div class="container-wide py-16 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
    <div>
      <span class="eyebrow">SEE IT NOW</span>
      <p class="mt-2 font-display text-2xl font-semibold text-ink-900">
        The live module in v0.0 is M10 · Document Triage.
      </p>
      <p class="mt-1 text-ink-600">A working demo of the same back-end architecture. Try it.</p>
    </div>
    <div class="flex gap-3">
      <a
        href={cta?.href ?? '/tools/triage'}
        class="inline-flex items-center gap-2 rounded-lg bg-ember-500 px-5 py-3 text-sm font-medium text-cream-50 shadow-lift hover:bg-ember-600 hover:-translate-y-px transition"
      >
        {cta?.label ?? 'Try the Document Triage demo'}
        <span aria-hidden="true">→</span>
      </a>
      <a
        href="/about/governance"
        class="inline-flex items-center gap-2 rounded-lg border border-bridge-200 px-5 py-3 text-sm font-medium text-bridge-700 hover:bg-bridge-50 transition"
      >
        Module status board
      </a>
    </div>
  </div>
</section>
