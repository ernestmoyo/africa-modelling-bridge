---
import Base from '@/layouts/Base.astro';
import StatusPill from '@/components/StatusPill.astro';
import { getCollection } from 'astro:content';

const dossiers = await getCollection('dossiers');

const countryFlagClass: Record<string, string> = {
  tanzania: 'bg-emerald-700 text-cream-50',
  malawi: 'bg-red-700 text-cream-50',
  drc: 'bg-blue-700 text-cream-50',
};

const countryLabel: Record<string, string> = {
  tanzania: 'Tanzania',
  malawi: 'Malawi',
  drc: 'DRC',
};

const difficultyLabel: Record<string, string> = {
  bsc: 'BSc',
  msc: 'MSc',
  phd: 'PhD',
  mixed: 'Mixed',
};

const anatomy = [
  { num: '01', title: 'The Question', line: 'A single sentence a programme manager would take into a meeting.' },
  { num: '02', title: 'Background', line: 'Why this question matters now, in this country, on this timeline.' },
  { num: '03', title: 'Data sources', line: 'Public datasets — HMIS, DHS, IDSR, NMCP bulletins — fully named.' },
  { num: '04', title: 'Methods landscape', line: 'The plausible methods, with the trade-offs and the right-sized choice.' },
  { num: '05', title: 'Starter pack', line: 'Code, data extracts, notebooks — enough to get the student to week 4.' },
  { num: '06', title: 'Success criteria', line: 'What a finished thesis or output actually has to show.' },
  { num: '07', title: 'How to take it up', line: 'BSc, MSc or PhD framing; supervisor channels; stipend mechanics.' },
  { num: '08', title: 'Supervision + adviser', line: 'Named local supervisor; named pro-bono methods adviser.' },
];

// Order dossiers: tanzania, malawi, drc for visual rhythm
const orderKey: Record<string, number> = { tanzania: 0, malawi: 1, drc: 2 };
const ordered = [...dossiers].sort(
  (a, b) => (orderKey[a.data.country] ?? 99) - (orderKey[b.data.country] ?? 99)
);
---

<Base
  title="Dossiers"
  description="Build-ready research packages, country-led — the AMB dossier portfolio. A dossier turns a vague topic into a build-ready package with question, data, methods, supervisor and budget."
>
  <!-- ───────────────────────── Hero ───────────────────────── -->
  <section class="relative overflow-hidden border-b border-bridge-100/60">
    <div class="absolute inset-0 -z-10 opacity-[0.5]" aria-hidden="true">
      <svg viewBox="0 0 1200 400" preserveAspectRatio="xMidYMid slice" class="h-full w-full">
        <g stroke="#c1ddda" stroke-width="1" fill="none">
          <rect x="100" y="80" width="180" height="240" rx="6" />
          <rect x="510" y="60" width="180" height="280" rx="6" />
          <rect x="920" y="100" width="180" height="220" rx="6" />
          <path d="M280,200 L510,200" stroke-dasharray="2 6" />
          <path d="M690,200 L920,200" stroke-dasharray="2 6" />
        </g>
      </svg>
    </div>
    <div class="grain-overlay opacity-[0.2]"></div>

    <div class="container-page relative pt-20 pb-16 sm:pt-24 sm:pb-20">
      <p class="eyebrow flex items-center gap-3">
        <span class="inline-block h-px w-8 bg-bridge-300"></span>
        Dossiers
      </p>
      <h1 class="mt-6 max-w-4xl font-display text-balance text-4xl font-light leading-[1.05] tracking-tightest text-ink-900 sm:text-5xl lg:text-6xl">
        Build-ready research packages,
        <span class="italic text-bridge-600">country-led.</span>
      </h1>
      <p class="mt-8 max-w-2xl text-lg leading-relaxed text-ink-600 text-pretty">
        A dossier turns a vague topic into a build-ready package — question, background, data
        sources, methods landscape, starter pack, success criteria, take-up pathway, supervisor.
        Full dossiers ship on v0.1. Previews are live now.
      </p>

      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="#portfolio"
          class="inline-flex items-center gap-2 rounded-md bg-bridge-600 px-5 py-3 text-sm font-medium text-cream-50 shadow-card transition hover:-translate-y-px hover:bg-bridge-700"
        >
          Read the portfolio
          <svg viewBox="0 0 20 20" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 4v12m0 0l-4-4m4 4l4-4" stroke-linecap="round" stroke-linejoin="round" /></svg>
        </a>
        <a
          href="/africa-modelling-bridge/support"
          class="inline-flex items-center gap-2 rounded-md border border-bridge-200 bg-cream-50 px-5 py-3 text-sm font-medium text-bridge-700 transition hover:border-bridge-500 hover:bg-bridge-50"
        >
          Support a dossier
        </a>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── What is a dossier ───────────────────────── -->
  <section class="border-b border-bridge-100/60 bg-cream-100/40">
    <div class="container-page py-16 sm:py-20">
      <div class="grid gap-12 lg:grid-cols-12">
        <div class="lg:col-span-5">
          <p class="eyebrow">What is a dossier?</p>
          <h2 class="mt-4 font-display text-3xl font-light leading-tight tracking-snug text-ink-900 sm:text-4xl text-balance">
            Eight sections. <span class="italic text-bridge-600">One question.</span>
          </h2>
          <p class="mt-6 text-lg leading-relaxed text-ink-600 text-pretty">
            Every dossier is built to the same anatomy. A funder can read the question and the
            budget ask in 90 seconds. A student can read the methods landscape and the starter pack
            in an afternoon and start the work the same week.
          </p>
        </div>

        <div class="lg:col-span-7">
          <ol class="grid gap-3 sm:grid-cols-2">
            {anatomy.map((s) => (
              <li class="flex gap-4 rounded-2xl border border-bridge-100/60 bg-cream-50 p-5 shadow-card">
                <span class="font-display text-2xl font-light tracking-tightest text-bridge-300">{s.num}</span>
                <div>
                  <p class="font-display text-sm font-medium text-ink-900">{s.title}</p>
                  <p class="mt-1 text-xs leading-relaxed text-ink-600">{s.line}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── Portfolio ───────────────────────── -->
  <section id="portfolio" class="border-b border-bridge-100/60">
    <div class="container-page py-16 sm:py-20">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="eyebrow">The portfolio</p>
          <h2 class="mt-4 font-display text-3xl font-light leading-tight tracking-snug text-ink-900 sm:text-4xl text-balance">
            Three countries. Three starter questions.
          </h2>
        </div>
        <p class="text-sm text-ink-400">{ordered.length} previews · {ordered.filter((d) => d.data.open_to_support).length} open to support</p>
      </div>

      <div class="mt-12 grid gap-6 lg:grid-cols-3">
        {ordered.map((d) => (
          <article class="group relative flex flex-col rounded-2xl border border-bridge-100/60 bg-cream-50 p-7 shadow-card transition hover:-translate-y-px hover:shadow-lift">
            <div class="flex flex-wrap items-center gap-2">
              <span class={`inline-flex items-center rounded-full px-2.5 py-0.5 font-mono text-[10px] uppercase tracking-[0.14em] ${countryFlagClass[d.data.country]}`}>
                {countryLabel[d.data.country]}
              </span>
              <span class="ml-auto"><StatusPill status="preview" small /></span>
            </div>

            <h3 class="mt-5 font-display text-xl font-medium leading-snug text-ink-900">
              {d.data.title}
            </h3>
            <p class="mt-3 text-sm leading-relaxed text-ink-600 text-pretty">{d.data.one_line}</p>

            <div class="mt-5 flex flex-wrap items-center gap-2">
              <span class="inline-flex items-center rounded-md bg-bridge-50 px-2 py-0.5 font-mono text-[10px] uppercase tracking-[0.14em] text-bridge-700">
                {difficultyLabel[d.data.difficulty]}
              </span>
              <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-ink-400">
                {d.data.time_estimate_months} months
              </span>
            </div>

            <div class="mt-5 flex flex-wrap gap-1.5">
              {d.data.methods.slice(0, 3).map((m) => (
                <span class="rounded-full border border-bridge-100 bg-cream-50 px-2 py-0.5 text-[11px] text-ink-600">
                  {m}
                </span>
              ))}
              {d.data.methods.length > 3 && (
                <span class="rounded-full px-2 py-0.5 text-[11px] text-ink-400">
                  +{d.data.methods.length - 3}
                </span>
              )}
            </div>

            <div class="mt-auto pt-6 border-t border-bridge-100/70">
              {d.data.open_to_support && d.data.budget_ask_usd && (
                <div class="flex items-center justify-between">
                  <div>
                    <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-ember-600">
                      Budget ask
                    </p>
                    <p class="mt-1 font-display text-xl font-light text-ink-900">
                      USD {d.data.budget_ask_usd.toLocaleString()}
                    </p>
                  </div>
                  <a
                    href={`/africa-modelling-bridge/dossiers/${d.slug}`}
                    class="text-sm font-medium text-bridge-700 link-underline"
                  >
                    Read preview →
                  </a>
                </div>
              )}
              {!d.data.open_to_support && (
                <a
                  href={`/africa-modelling-bridge/dossiers/${d.slug}`}
                  class="text-sm font-medium text-bridge-700 link-underline"
                >
                  Read preview →
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ───────────────────────── Coming soon ───────────────────────── -->
  <section class="bg-cream-100">
    <div class="container-page py-16 sm:py-20">
      <div class="grid items-center gap-10 lg:grid-cols-12">
        <div class="lg:col-span-7">
          <p class="eyebrow">Coming soon</p>
          <h2 class="mt-4 font-display text-3xl font-light leading-tight tracking-snug text-ink-900 sm:text-4xl text-balance">
            Year-one target: <span class="italic text-bridge-600">20+ dossiers.</span>
          </h2>
          <p class="mt-5 max-w-xl text-lg leading-relaxed text-ink-600 text-pretty">
            Three previews today. Twenty-plus full dossiers across Tanzania, Malawi and DRC by the
            end of year one — at least 30% with an AI-assisted scaffold (M11 Dossier Co-Author).
            Every dossier publishes with a DOI'd archive on the platform.
          </p>
        </div>

        <div class="lg:col-span-5">
          <div class="grid gap-3 sm:grid-cols-3">
            <div class="rounded-xl border border-bridge-100 bg-cream-50 p-4 text-center">
              <p class="font-display text-3xl font-light text-bridge-600">3</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.18em] text-ink-400">
                Live previews
              </p>
            </div>
            <div class="rounded-xl border border-bridge-100 bg-cream-50 p-4 text-center">
              <p class="font-display text-3xl font-light text-ember-600">20<span class="text-lg">+</span></p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.18em] text-ink-400">
                Year-1 target
              </p>
            </div>
            <div class="rounded-xl border border-bridge-100 bg-cream-50 p-4 text-center">
              <p class="font-display text-3xl font-light text-bridge-600">30<span class="text-lg">%</span></p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.18em] text-ink-400">
                AI-assisted
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
