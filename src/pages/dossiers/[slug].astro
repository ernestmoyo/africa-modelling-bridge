---
import Base from '@/layouts/Base.astro';
import StatusPill from '@/components/StatusPill.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const items = await getCollection('dossiers');
  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item, all: items },
  }));
}

interface Props {
  item: CollectionEntry<'dossiers'>;
  all: CollectionEntry<'dossiers'>[];
}

const { item, all } = Astro.props;
const { Content } = await item.render();
const {
  title,
  slug,
  country,
  ministry,
  sector,
  disease_or_theme,
  difficulty,
  time_estimate_months,
  methods,
  budget_ask_usd,
  open_to_support,
  one_line,
  why_it_matters,
} = item.data;

const countryFlagClass: Record<string, string> = {
  tanzania: 'bg-emerald-700 text-cream-50',
  malawi: 'bg-red-700 text-cream-50',
  drc: 'bg-blue-700 text-cream-50',
};
const countryLabel: Record<string, string> = {
  tanzania: 'Tanzania',
  malawi: 'Malawi',
  drc: 'DRC',
};
const difficultyLabel: Record<string, string> = {
  bsc: 'BSc',
  msc: 'MSc',
  phd: 'PhD',
  mixed: 'Mixed',
};

const adjacent = all.filter((d) => d.slug !== slug).slice(0, 2);
---

<Base
  title={title}
  description={one_line}
>
  <!-- ───────────────────────── Header ───────────────────────── -->
  <section class="border-b border-bridge-100/60 bg-cream-100/40">
    <div class="container-page py-12 sm:py-16">
      <nav class="font-mono text-[11px] uppercase tracking-[0.18em] text-ink-400">
        <a href="/" class="hover:text-bridge-700">Home</a>
        <span class="mx-2 text-bridge-300">/</span>
        <a href="/dossiers" class="hover:text-bridge-700">Dossiers</a>
        <span class="mx-2 text-bridge-300">/</span>
        <a href={`/countries/${country}`} class="hover:text-bridge-700">{countryLabel[country]}</a>
        <span class="mx-2 text-bridge-300">/</span>
        <span class="text-ink-700 normal-case tracking-normal font-sans">preview</span>
      </nav>

      <div class="mt-8 flex flex-wrap items-center gap-2">
        <span class={`inline-flex items-center rounded-full px-2.5 py-0.5 font-mono text-[10px] uppercase tracking-[0.14em] ${countryFlagClass[country]}`}>
          {countryLabel[country]}
        </span>
        <span class="inline-flex items-center rounded-full border border-bridge-200 bg-cream-50 px-2.5 py-0.5 text-xs text-bridge-700">
          {sector}
        </span>
        <span class="inline-flex items-center rounded-full border border-bridge-200 bg-cream-50 px-2.5 py-0.5 text-xs text-bridge-700">
          {disease_or_theme}
        </span>
        <StatusPill status="preview" />
      </div>

      <h1 class="mt-6 max-w-4xl font-display text-balance text-3xl font-light leading-[1.1] tracking-tightest text-ink-900 sm:text-4xl lg:text-5xl">
        {title}
      </h1>
      <p class="mt-5 max-w-3xl text-lg leading-relaxed text-ink-600 text-pretty">{one_line}</p>

      <p class="mt-6 text-sm text-ink-400">
        <span class="font-mono uppercase tracking-[0.14em] text-bridge-600">Ministry · </span>
        {ministry}
      </p>
    </div>
  </section>

  <!-- ───────────────────────── Metadata strip ───────────────────────── -->
  <section class="border-b border-bridge-100/60 bg-cream-50">
    <div class="container-page py-6">
      <dl class="grid grid-cols-2 gap-6 sm:grid-cols-4">
        <div>
          <dt class="font-mono text-[10px] uppercase tracking-[0.18em] text-bridge-600">Difficulty</dt>
          <dd class="mt-1 font-display text-lg font-light text-ink-900">{difficultyLabel[difficulty]}</dd>
        </div>
        <div>
          <dt class="font-mono text-[10px] uppercase tracking-[0.18em] text-bridge-600">Timeline</dt>
          <dd class="mt-1 font-display text-lg font-light text-ink-900">{time_estimate_months} months</dd>
        </div>
        <div>
          <dt class="font-mono text-[10px] uppercase tracking-[0.18em] text-bridge-600">Methods</dt>
          <dd class="mt-1 text-sm text-ink-700">{methods.length} listed</dd>
        </div>
        <div>
          <dt class="font-mono text-[10px] uppercase tracking-[0.18em] text-bridge-600">Budget ask</dt>
          <dd class="mt-1 font-display text-lg font-light text-ink-900">
            {budget_ask_usd ? `USD ${budget_ask_usd.toLocaleString()}` : '—'}
          </dd>
        </div>
      </dl>

      <div class="mt-4 flex flex-wrap gap-1.5 border-t border-bridge-100/60 pt-4">
        {methods.map((m) => (
          <span class="rounded-full border border-bridge-100 bg-cream-50 px-2.5 py-0.5 text-[11px] text-ink-700">
            {m}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ───────────────────────── Why it matters ───────────────────────── -->
  <section class="border-b border-bridge-100/60">
    <div class="container-page py-16 sm:py-20">
      <div class="grid gap-10 lg:grid-cols-12">
        <div class="lg:col-span-8">
          <div class="rounded-2xl border-l-4 border-ember-500 bg-ember-50 p-7">
            <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-ember-700">Why it matters</p>
            <p class="mt-3 text-lg leading-relaxed text-ink-800 text-pretty">{why_it_matters}</p>
          </div>

          <div class="mt-12 prose prose-lg max-w-readable text-ink-700 prose-headings:font-display prose-headings:font-medium prose-headings:text-ink-900 prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4 prose-h3:text-xl prose-a:text-bridge-700 prose-a:no-underline hover:prose-a:underline prose-blockquote:border-l-2 prose-blockquote:border-bridge-300 prose-blockquote:bg-cream-100/40 prose-blockquote:not-italic prose-blockquote:text-ink-600 prose-blockquote:py-2 prose-blockquote:px-5 prose-blockquote:rounded-r-lg">
            <Content />
          </div>
        </div>

        <aside class="lg:col-span-4">
          {open_to_support && budget_ask_usd && (
            <div class="sticky top-24 rounded-2xl border border-ember-200 bg-ember-50 p-6 shadow-card">
              <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-ember-700">
                Open to support
              </p>
              <p class="mt-3 font-display text-4xl font-light text-ink-900">
                USD {budget_ask_usd.toLocaleString()}
              </p>
              <p class="mt-2 text-xs text-ink-600">
                Funds {time_estimate_months}-month {difficultyLabel[difficulty]} project — stipend,
                methods adviser, supervisor honorarium, compute.
              </p>

              <a
                href={`/support#${slug}`}
                class="mt-5 inline-flex w-full items-center justify-center gap-2 rounded-md bg-ember-500 px-4 py-2.5 text-sm font-medium text-cream-50 shadow-card transition hover:-translate-y-px hover:bg-ember-600"
              >
                Support this dossier
                <svg viewBox="0 0 20 20" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke-linecap="round" stroke-linejoin="round" /></svg>
              </a>

              <dl class="mt-6 space-y-3 border-t border-ember-200 pt-5 text-xs">
                <div class="flex justify-between gap-3">
                  <dt class="text-ember-700">Country</dt>
                  <dd class="text-ink-700">{countryLabel[country]}</dd>
                </div>
                <div class="flex justify-between gap-3">
                  <dt class="text-ember-700">Sector</dt>
                  <dd class="text-ink-700">{sector}</dd>
                </div>
                <div class="flex justify-between gap-3">
                  <dt class="text-ember-700">Theme</dt>
                  <dd class="text-ink-700">{disease_or_theme}</dd>
                </div>
              </dl>
            </div>
          )}

          {!open_to_support && (
            <div class="sticky top-24 rounded-2xl border border-bridge-100/60 bg-cream-50 p-6 shadow-card">
              <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-bridge-600">Status</p>
              <p class="mt-3 font-display text-xl font-light text-ink-900">
                Not currently open to support
              </p>
              <p class="mt-3 text-sm leading-relaxed text-ink-600">
                Preview dossier — full version publishes on v0.1.
              </p>
            </div>
          )}
        </aside>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── Adjacent dossiers ───────────────────────── -->
  <section class="border-b border-bridge-100/60 bg-cream-100/40">
    <div class="container-page py-16">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="eyebrow">Adjacent dossiers</p>
          <h2 class="mt-3 font-display text-2xl font-light text-ink-900 sm:text-3xl text-balance">
            Other questions on the table.
          </h2>
        </div>
        <a href="/dossiers" class="text-sm font-medium text-bridge-700 link-underline">
          All dossiers →
        </a>
      </div>

      <div class="mt-8 grid gap-6 md:grid-cols-2">
        {adjacent.map((d) => (
          <a
            href={`/dossiers/${d.slug}`}
            class="group flex flex-col rounded-2xl border border-bridge-100/60 bg-cream-50 p-6 shadow-card transition hover:-translate-y-px hover:shadow-lift"
          >
            <div class="flex flex-wrap items-center gap-2">
              <span class={`inline-flex items-center rounded-full px-2.5 py-0.5 font-mono text-[10px] uppercase tracking-[0.14em] ${countryFlagClass[d.data.country]}`}>
                {countryLabel[d.data.country]}
              </span>
              <span class="inline-flex items-center rounded-md bg-bridge-50 px-2 py-0.5 font-mono text-[10px] uppercase tracking-[0.14em] text-bridge-700">
                {difficultyLabel[d.data.difficulty]}
              </span>
            </div>
            <h3 class="mt-4 font-display text-lg font-medium leading-snug text-ink-900 group-hover:text-bridge-700">
              {d.data.title}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-600">{d.data.one_line}</p>
            <p class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-bridge-700 link-underline">
              Read preview →
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
