---
import Base from '@/layouts/Base.astro';
import StatusPill from '@/components/StatusPill.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const items = await getCollection('countries');
  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

interface Props {
  item: CollectionEntry<'countries'>;
}

const { item } = Astro.props;
const { Content } = await item.render();
const { name, slug, region, languages, anchor } = item.data;

const allDossiers = await getCollection('dossiers');
const dossiers = allDossiers.filter((d) => d.data.country === slug);

const allResearchers = await getCollection('researchers');
const researchers = allResearchers.filter((r) => {
  const c = (r.data.country ?? '').toLowerCase();
  return (
    c === name.toLowerCase() ||
    c === slug ||
    (slug === 'drc' && c.includes('congo'))
  );
});

const countryFlagClass: Record<string, string> = {
  tanzania: 'bg-emerald-700 text-cream-50',
  malawi: 'bg-red-700 text-cream-50',
  drc: 'bg-blue-700 text-cream-50',
};

const difficultyLabel: Record<string, string> = {
  bsc: 'BSc',
  msc: 'MSc',
  phd: 'PhD',
  mixed: 'Mixed',
};

const initialsFor = (n: string): string =>
  n
    .replace(/—.*/, '')
    .trim()
    .split(/\s+/)
    .map((p) => p[0])
    .slice(0, 2)
    .join('')
    .toUpperCase();
---

<Base
  title={name}
  description={`${name} — country page on the Africa Modelling Bridge. Anchor, document index, dossiers, researchers and upcoming sessions.`}
>
  <!-- ───────────────────────── Hero ───────────────────────── -->
  <section class="relative overflow-hidden border-b border-bridge-100/60">
    <div class="absolute inset-0 -z-10 opacity-[0.5]" aria-hidden="true">
      <svg viewBox="0 0 1200 400" preserveAspectRatio="xMidYMid slice" class="h-full w-full">
        <g stroke="#c1ddda" stroke-width="1" fill="none">
          <path d="M0,260 C200,200 380,240 600,200 C820,160 980,240 1200,200" />
          <path d="M0,300 C200,240 380,280 600,240 C820,200 980,280 1200,240" />
          <path d="M0,340 C200,280 380,320 600,280 C820,240 980,320 1200,280" />
        </g>
      </svg>
    </div>
    <div class="grain-overlay opacity-[0.2]"></div>

    <div class="container-page relative pt-16 pb-16 sm:pt-20 sm:pb-20">
      <nav class="font-mono text-[11px] uppercase tracking-[0.18em] text-ink-400">
        <a href="/" class="hover:text-bridge-700">Home</a>
        <span class="mx-2 text-bridge-300">/</span>
        <span class="text-bridge-700">Countries</span>
        <span class="mx-2 text-bridge-300">/</span>
        <span class="text-ink-700">{name}</span>
      </nav>

      <p class="eyebrow mt-8 flex items-center gap-3">
        <span class="inline-block h-px w-8 bg-bridge-300"></span>
        Country · {region}
      </p>
      <h1 class="mt-5 max-w-4xl font-display text-balance text-5xl font-light leading-[1.05] tracking-tightest text-ink-900 sm:text-6xl lg:text-7xl">
        {name}
      </h1>

      <div class="mt-8 flex flex-wrap gap-2">
        {languages.map((lang) => (
          <span class="inline-flex items-center rounded-full border border-bridge-200 bg-cream-50 px-3 py-1 text-xs font-medium text-bridge-700">
            {lang}
          </span>
        ))}
      </div>

      <!-- Anchor card -->
      <div class="mt-12 max-w-xl rounded-2xl border border-bridge-100/60 bg-cream-50 p-6 shadow-card">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-bridge-600">
              Country Anchor
            </p>
            <p class="mt-2 font-display text-2xl font-light text-ink-900">{anchor.name}</p>
            <p class="mt-1 text-sm text-ink-600">{anchor.role}</p>
          </div>
          {anchor.placeholder && <StatusPill status="preview" />}
        </div>
        <p class="mt-5 border-t border-bridge-100/70 pt-4 text-xs leading-relaxed text-ink-400">
          The anchor co-curates the Layer-0 document index, hosts the first dialogue session, and
          supervises the starter dossier. Confirmed identity lands on v0.1.
        </p>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── Summary ───────────────────────── -->
  <section class="border-b border-bridge-100/60">
    <div class="container-page py-16 sm:py-20">
      <div class="grid gap-12 lg:grid-cols-12">
        <div class="lg:col-span-4">
          <p class="eyebrow">Summary</p>
          <h2 class="mt-4 font-display text-3xl font-light leading-tight tracking-snug text-ink-900 text-balance">
            Why this country, first.
          </h2>
        </div>
        <div class="lg:col-span-8">
          <div class="prose prose-lg max-w-readable text-ink-700 prose-headings:font-display prose-headings:font-medium prose-headings:text-ink-900 prose-a:text-bridge-700 prose-a:no-underline hover:prose-a:underline">
            <Content />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── Active dossiers ───────────────────────── -->
  <section class="border-b border-bridge-100/60 bg-cream-100/40">
    <div class="container-page py-16 sm:py-20">
      <div class="flex flex-wrap items-end justify-between gap-6">
        <div>
          <p class="eyebrow">Active dossiers</p>
          <h2 class="mt-4 font-display text-3xl font-light leading-tight tracking-snug text-ink-900 sm:text-4xl text-balance">
            The questions on the table in {name}.
          </h2>
        </div>
        <a href="/dossiers" class="text-sm font-medium text-bridge-700 link-underline">
          All dossiers →
        </a>
      </div>

      {dossiers.length === 0 ? (
        <p class="mt-10 text-ink-600">No dossiers indexed yet for {name}.</p>
      ) : (
        <div class="mt-10 grid gap-6 md:grid-cols-2">
          {dossiers.map((d) => (
            <article class="group relative flex flex-col rounded-2xl border border-bridge-100/60 bg-cream-50 p-7 shadow-card transition hover:-translate-y-px hover:shadow-lift">
              <div class="flex flex-wrap items-center gap-2">
                <span class={`inline-flex items-center rounded-full px-2.5 py-0.5 font-mono text-[9px] uppercase tracking-[0.14em] ${countryFlagClass[d.data.country]}`}>
                  {d.data.country}
                </span>
                <span class="inline-flex items-center rounded-md bg-bridge-50 px-2 py-0.5 font-mono text-[9px] uppercase tracking-[0.14em] text-bridge-700">
                  {difficultyLabel[d.data.difficulty]}
                </span>
                <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-ink-400">
                  {d.data.time_estimate_months} mo
                </span>
                <span class="ml-auto"><StatusPill status="preview" small /></span>
              </div>
              <h3 class="mt-5 font-display text-xl font-medium leading-snug text-ink-900">
                {d.data.title}
              </h3>
              <p class="mt-3 text-sm leading-relaxed text-ink-600">{d.data.one_line}</p>

              <div class="mt-5 flex flex-wrap gap-1.5">
                {d.data.methods.slice(0, 3).map((m) => (
                  <span class="rounded-full border border-bridge-100 bg-cream-50 px-2 py-0.5 text-[11px] text-ink-600">
                    {m}
                  </span>
                ))}
                {d.data.methods.length > 3 && (
                  <span class="rounded-full px-2 py-0.5 text-[11px] text-ink-400">
                    +{d.data.methods.length - 3} more
                  </span>
                )}
              </div>

              <div class="mt-6 flex items-end justify-between border-t border-bridge-100/70 pt-4">
                {d.data.open_to_support && d.data.budget_ask_usd ? (
                  <div>
                    <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-ember-600">
                      Open to support
                    </p>
                    <p class="mt-1 font-display text-lg font-light text-ink-900">
                      USD {d.data.budget_ask_usd.toLocaleString()}
                    </p>
                  </div>
                ) : <div />}
                <a
                  href={`/dossiers/${d.slug}`}
                  class="text-sm font-medium text-bridge-700 link-underline"
                >
                  Read preview →
                </a>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- ───────────────────────── Documents indexed ───────────────────────── -->
  <section class="border-b border-bridge-100/60">
    <div class="container-page py-16 sm:py-20">
      <div class="grid gap-10 lg:grid-cols-12">
        <div class="lg:col-span-5">
          <p class="eyebrow">Layer 0 · Documents indexed</p>
          <h2 class="mt-4 font-display text-3xl font-light leading-tight tracking-snug text-ink-900 text-balance">
            Public ministry record, made citable.
          </h2>
        </div>
        <div class="lg:col-span-7">
          <div class="rounded-2xl border border-bridge-100/60 bg-cream-50 p-7 shadow-card">
            <div class="flex items-center justify-between">
              <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-bridge-600">
                Document index · {name}
              </p>
              <StatusPill status="coming-v0_1" />
            </div>
            <p class="mt-5 text-base leading-relaxed text-ink-600">
              The Layer 0 document index lands on v0.1 with a target of 20 publicly available
              Ministry of Health and NMCP documents per country — strategic plans, surveillance
              bulletins, district performance reports — parsed, indexed, citable.
            </p>
            <dl class="mt-6 grid grid-cols-3 gap-4 border-t border-bridge-100/70 pt-5 text-sm">
              <div>
                <dt class="font-mono text-[10px] uppercase tracking-[0.18em] text-ink-400">Target</dt>
                <dd class="mt-1 font-display text-2xl font-light text-ink-900">20</dd>
              </div>
              <div>
                <dt class="font-mono text-[10px] uppercase tracking-[0.18em] text-ink-400">Indexed</dt>
                <dd class="mt-1 font-display text-2xl font-light text-ink-400">0</dd>
              </div>
              <div>
                <dt class="font-mono text-[10px] uppercase tracking-[0.18em] text-ink-400">Languages</dt>
                <dd class="mt-1 text-xs leading-tight text-ink-700">{languages.join(' · ')}</dd>
              </div>
            </dl>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── Researchers based here ───────────────────────── -->
  <section class="border-b border-bridge-100/60 bg-cream-100/40">
    <div class="container-page py-16 sm:py-20">
      <div class="flex flex-wrap items-end justify-between gap-6">
        <div>
          <p class="eyebrow">Researchers based here</p>
          <h2 class="mt-4 font-display text-3xl font-light leading-tight tracking-snug text-ink-900 sm:text-4xl text-balance">
            The people doing the work in {name}.
          </h2>
        </div>
        <a href="/researchers" class="text-sm font-medium text-bridge-700 link-underline">
          All researchers →
        </a>
      </div>

      {researchers.length === 0 ? (
        <p class="mt-10 text-ink-600">No researchers listed for {name} yet.</p>
      ) : (
        <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {researchers.map((r) => (
            <a
              href={`/researchers/${r.slug}`}
              class="group flex items-start gap-4 rounded-2xl border border-bridge-100/60 bg-cream-50 p-5 shadow-card transition hover:-translate-y-px hover:shadow-lift"
            >
              <div
                class={`grid h-12 w-12 shrink-0 place-items-center rounded-full font-display text-base font-medium ${
                  r.data.placeholder
                    ? 'bg-cream-300 text-ink-600'
                    : 'bg-bridge-600 text-cream-50'
                }`}
                aria-hidden="true"
              >
                {initialsFor(r.data.name)}
              </div>
              <div class="min-w-0">
                <p class="font-display text-base font-medium leading-tight text-ink-900 group-hover:text-bridge-700">
                  {r.data.name}
                </p>
                <p class="mt-1 text-xs text-bridge-700">{r.data.role}</p>
                {r.data.institution && (
                  <p class="mt-1 text-[11px] text-ink-400">{r.data.institution}</p>
                )}
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- ───────────────────────── Upcoming sessions ───────────────────────── -->
  <section class="border-b border-bridge-100/60">
    <div class="container-page py-16 sm:py-20">
      <div class="grid gap-10 lg:grid-cols-12">
        <div class="lg:col-span-5">
          <p class="eyebrow">Upcoming sessions</p>
          <h2 class="mt-4 font-display text-3xl font-light leading-tight tracking-snug text-ink-900 text-balance">
            Dialogue and discovery, on the ground.
          </h2>
        </div>
        <div class="lg:col-span-7">
          <div class="rounded-2xl border border-bridge-100/60 bg-cream-50 p-7 shadow-card">
            <div class="flex items-center justify-between">
              <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-bridge-600">
                Session schedule · {name}
              </p>
              <StatusPill status="coming-v0_5" />
            </div>
            <p class="mt-5 text-base leading-relaxed text-ink-600">
              The first dialogue + discovery session in {name} lands on v0.5 — a small in-person
              room with the anchor, the ministry, the local university supervisor, and two or three
              candidate students. Shared meal. No rank. No exclusion.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── CTA strip ───────────────────────── -->
  <section class="bg-bridge-700 text-cream-50">
    <div class="container-page py-16 sm:py-20">
      <div class="grid items-center gap-10 lg:grid-cols-12">
        <div class="lg:col-span-7">
          <h2 class="font-display text-3xl font-light leading-tight tracking-snug text-cream-50 sm:text-4xl text-balance">
            See the dossiers.
            <span class="italic text-ember-200">Support the work.</span>
          </h2>
          <p class="mt-4 max-w-xl text-base leading-relaxed text-cream-100/80">
            Every {name} dossier is a single question with a feasible timeline and a named budget.
            Funders can move from interest to a funded project in days.
          </p>
        </div>
        <div class="lg:col-span-5 flex flex-wrap gap-3 lg:justify-end">
          <a
            href="/dossiers"
            class="inline-flex items-center gap-2 rounded-md bg-ember-500 px-5 py-3 text-sm font-medium text-cream-50 shadow-card transition hover:-translate-y-px hover:bg-ember-600"
          >
            Browse dossiers
            <svg viewBox="0 0 20 20" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </a>
          <a
            href="/support"
            class="inline-flex items-center gap-2 rounded-md border border-cream-50/30 bg-bridge-700 px-5 py-3 text-sm font-medium text-cream-50 transition hover:border-cream-50 hover:bg-bridge-600"
          >
            Funder pathway
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>
