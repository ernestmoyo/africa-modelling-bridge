---
import Base from '@/layouts/Base.astro';
import ModuleStatusBoard from '@/components/ModuleStatusBoard.astro';

const editorialSteps: { id: string; title: string; body: string }[] = [
  {
    id: '01',
    title: 'Draft on a branch',
    body: 'Editor opens a branch — either via git locally, or via Decap CMS in the browser from v0.1. Drafts are markdown in src/content/.',
  },
  {
    id: '02',
    title: 'Pull request, public',
    body: 'Every change is a PR against main. AI-generated drafts are tagged and require a human editor before merge.',
  },
  {
    id: '03',
    title: 'Review · methods · facts',
    body: 'Lead consultant signs off on every PR. Methods content is additionally reviewed by the named working-modeller adviser for that dossier.',
  },
  {
    id: '04',
    title: 'Auto-deploy on merge',
    body: 'Merge triggers a Netlify build. The audit trail is the git history — every change is signed, dated, and addressable.',
  },
];

const releases: {
  version: string;
  ship: string;
  headline: string;
  deliverables: string[];
  current?: boolean;
}[] = [
  {
    version: 'v0.0',
    ship: 'Q3 2026',
    headline: 'Funder prototype',
    deliverables: [
      'Module status board live',
      'M10 Document Triage demo',
      'Country pages (TZ · MW · DRC)',
      'Researcher profiles · 4',
      'Newsletter signup',
      'Take-down policy published',
    ],
    current: true,
  },
  {
    version: 'v0.1',
    ship: 'Q4 2026',
    headline: 'First real content',
    deliverables: [
      'TZ document index · 20 entries',
      '3 full dossiers',
      'Decap CMS for editors',
      'Take-down request form',
      'First newsletter issue',
    ],
  },
  {
    version: 'v0.5',
    ship: 'Q2 2027',
    headline: 'The collaborative is on',
    deliverables: [
      '40 documents · 8 dossiers',
      'Open API · Researchers + Dossiers',
      'Public token-spend dashboard',
      'Take-down public log',
      'First spotlight researcher',
    ],
  },
  {
    version: 'v1.0',
    ship: 'Q4 2027',
    headline: 'Country-led',
    deliverables: [
      '60 documents · 12 dossiers',
      '12 confirmed researchers',
      'DRC EN/FR bilingual',
      'Methods coach live',
      'AI document search live',
    ],
  },
  {
    version: 'v1.5',
    ship: 'Q2 2028',
    headline: 'Compound the network',
    deliverables: [
      'Personalised funder matches',
      'Spotlight pushed to partner networks',
      'Refined translation pipeline',
      'M10 open to ministry contacts',
    ],
  },
  {
    version: 'v2.0',
    ship: 'TBD',
    headline: 'Continental',
    deliverables: [
      'Five more pilot countries',
      'Permanent operating model',
      'Sustainability finance committed',
    ],
  },
];

const tranche: { label: string; pct: number; usd: string; tone: string; barClass: string }[] = [
  {
    label: 'Engagement · sessions · field',
    pct: 58,
    usd: '$29,000 of $50k scenario',
    tone: 'People in rooms. Anchor honoraria. Field travel. Session catering.',
    barClass: 'bg-bridge-600',
  },
  {
    label: 'Platform · AI tokens · compute',
    pct: 24,
    usd: '$12,000 of $50k scenario',
    tone: 'Hosting, model API tokens, embeddings, CMS. Visible in the public spend dashboard from v0.5.',
    barClass: 'bg-ember-500',
  },
  {
    label: 'Brand · comms · MEL · contingency',
    pct: 18,
    usd: '$9,000 of $50k scenario',
    tone: 'Visual identity, newsletter, monitoring + evaluation, and a real contingency line.',
    barClass: 'bg-bridge-300',
  },
];
---

<Base title="Governance" description="The module status board, editorial workflow, take-down policy, public token-spend commitment, budget transparency and roadmap for Africa Modelling Bridge.">

  <!-- Hero -->
  <section class="border-b border-bridge-100/60 bg-cream-50 relative overflow-hidden">
    <div class="grain-overlay"></div>
    <div class="container-page relative py-20 sm:py-28">
      <div class="grid gap-12 lg:grid-cols-12 lg:items-end">
        <div class="lg:col-span-8">
          <p class="font-mono text-xs uppercase tracking-[0.22em] text-bridge-600 mb-6">Governance &amp; module status</p>
          <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-semibold tracking-tightest text-ink-900 text-balance leading-[1.05]">
            Built in public,<br class="hidden sm:block" />
            <span class="text-bridge-600">module by module.</span>
          </h1>
          <p class="mt-8 max-w-readable text-lg sm:text-xl text-ink-600 leading-relaxed text-pretty">
            Funder-grade governance from v0.0. Every change is a public pull request. Every take-down
            request is logged with its outcome. From v0.5 you can watch month-to-date AI token spend
            per module from the same page as the site itself.
          </p>
        </div>
        <div class="lg:col-span-4">
          <div class="rounded-2xl border border-bridge-100/70 bg-cream-100/60 p-6 shadow-card space-y-4">
            <div>
              <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-bridge-600">Repo</p>
              <p class="font-mono text-sm text-ink-800 mt-1">github · public</p>
            </div>
            <div>
              <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-bridge-600">Licence</p>
              <p class="font-mono text-sm text-ink-800 mt-1">text CC-BY · code MIT</p>
            </div>
            <div>
              <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-bridge-600">DOI service</p>
              <p class="font-mono text-sm text-ink-800 mt-1">Zenodo</p>
            </div>
            <div>
              <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-bridge-600">Take-down SLO</p>
              <p class="font-mono text-sm text-ember-600 mt-1">5 business days</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Platform is modular -->
  <section class="border-b border-bridge-100/40">
    <div class="container-page py-20 sm:py-24">
      <div class="grid gap-14 lg:grid-cols-12">
        <div class="lg:col-span-4">
          <p class="eyebrow mb-4">The argument</p>
          <h2 class="font-display text-3xl sm:text-4xl font-semibold tracking-snug text-ink-900 text-balance">
            The platform is modular.
          </h2>
        </div>
        <div class="lg:col-span-8 space-y-5 max-w-readable">
          <p class="text-lg text-ink-700 leading-relaxed text-pretty">
            Every feature ships as a discrete module with its own owner, budget, surface, and on/off
            switch. A funder can sponsor a single module. If any module is turned off, the rest still
            build. This is the funder protection — and it is the operational protection too, because it
            means a delay on one piece never blocks the others.
          </p>
          <p class="text-base text-ink-600 leading-relaxed text-pretty">
            The twenty modules fall into four families:
            <strong class="text-ink-800">Data spine</strong> (the public information layer),
            <strong class="text-ink-800">People</strong> (researchers and funders made routable),
            <strong class="text-ink-800">AI-powered</strong> (frontier models applied in narrow, edited loops), and
            <strong class="text-ink-800">Operations</strong> (the governance, distribution and audit layer that makes the rest credible).
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- MODULE STATUS BOARD -->
  <section class="border-b border-bridge-100/40 bg-cream-100/30">
    <div class="container-wide py-20 sm:py-24">
      <ModuleStatusBoard />
    </div>
  </section>

  <!-- Editorial workflow -->
  <section class="border-b border-bridge-100/40">
    <div class="container-page py-20 sm:py-24">
      <div class="grid gap-14 lg:grid-cols-12">
        <div class="lg:col-span-4">
          <p class="eyebrow mb-4">Editorial workflow</p>
          <h2 class="font-display text-3xl sm:text-4xl font-semibold tracking-snug text-ink-900 text-balance">
            Git + PR + Decap CMS.
          </h2>
          <p class="mt-6 text-base text-ink-600 leading-relaxed text-pretty max-w-prose">
            The audit trail is the governance. Every word on the site is reachable as a public commit
            with an editor, a timestamp, and a diff.
          </p>
        </div>
        <div class="lg:col-span-8">
          <ol class="space-y-px rounded-2xl overflow-hidden border border-bridge-100/60 bg-bridge-100/40">
            {editorialSteps.map((step) => (
              <li class="bg-cream-50 p-6 sm:p-7 flex gap-6">
                <span class="flex-none font-mono text-xs uppercase tracking-[0.18em] text-bridge-500 pt-1.5">
                  {step.id}
                </span>
                <div>
                  <p class="font-display text-lg font-semibold text-ink-900">{step.title}</p>
                  <p class="mt-1.5 text-sm text-ink-600 leading-relaxed text-pretty">{step.body}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- Take-down policy -->
  <section class="border-b border-bridge-100/40 bg-cream-100/40">
    <div class="container-page py-20 sm:py-24">
      <div class="max-w-readable">
        <p class="eyebrow mb-4">Take-down policy</p>
        <h2 class="font-display text-3xl sm:text-4xl font-semibold tracking-snug text-ink-900 text-balance">
          Five business days. Every request logged.
        </h2>
        <p class="mt-6 text-lg text-ink-700 leading-relaxed text-pretty">
          Every document we index is already in the public domain. We still honour ministry take-down
          requests — within five business days, with a public log of every request and its
          outcome. Trust takes years to build and one uncorrected mistake to erode. The policy is the
          floor. M17 implements it.
        </p>
        <div class="mt-8 grid gap-4 sm:grid-cols-3">
          <div class="rounded-xl border border-bridge-100/60 bg-cream-50 p-5">
            <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-bridge-600 mb-2">Window</p>
            <p class="font-display text-2xl font-semibold text-ink-900">5 days</p>
            <p class="text-xs text-ink-500 mt-1">Working days from request receipt.</p>
          </div>
          <div class="rounded-xl border border-bridge-100/60 bg-cream-50 p-5">
            <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-bridge-600 mb-2">Record</p>
            <p class="font-display text-2xl font-semibold text-ink-900">Public log</p>
            <p class="text-xs text-ink-500 mt-1">Every request, every outcome — from v0.5.</p>
          </div>
          <div class="rounded-xl border border-bridge-100/60 bg-cream-50 p-5">
            <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-bridge-600 mb-2">Standing</p>
            <p class="font-display text-2xl font-semibold text-ink-900">Ministry</p>
            <p class="text-xs text-ink-500 mt-1">Originating ministry of the document, or its successor.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Public token-spend -->
  <section class="border-b border-bridge-100/40 bg-bridge-700 text-cream-50 relative overflow-hidden">
    <div class="grain-overlay opacity-[0.25]"></div>
    <div class="container-page relative py-20 sm:py-24">
      <div class="grid gap-12 lg:grid-cols-12 items-start">
        <div class="lg:col-span-7">
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-bridge-200 mb-4">Public token-spend</p>
          <h2 class="font-display text-3xl sm:text-4xl font-semibold tracking-snug text-cream-50 text-balance leading-tight">
            If you're paying for AI tokens, you can see what they bought.
          </h2>
          <p class="mt-6 text-lg text-bridge-100/90 leading-relaxed text-pretty max-w-prose">
            From v0.5, the public analytics dashboard shows month-to-date AI spend per module — M10
            triage, M11 co-author, M13 search, M15 translation. The line item, the model, the
            tokens, the cost. No black box. Funder-grade by default, not by request.
          </p>
        </div>
        <div class="lg:col-span-5">
          <div class="rounded-2xl border border-bridge-500/30 bg-bridge-800/40 p-6 backdrop-blur">
            <div class="flex items-center justify-between mb-4">
              <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-ember-200">Preview · v0.5</p>
              <p class="font-mono text-[10px] text-bridge-200/70">MTD · USD</p>
            </div>
            <ul class="space-y-3">
              {[
                { id: 'M10', name: 'Document Triage', val: '$ —', share: 60 },
                { id: 'M11', name: 'Co-author', val: '$ —', share: 20 },
                { id: 'M13', name: 'AI Search', val: '$ —', share: 12 },
                { id: 'M15', name: 'Translation', val: '$ —', share: 8 },
              ].map((row) => (
                <li>
                  <div class="flex items-baseline justify-between gap-3 mb-1.5">
                    <span class="font-mono text-xs text-bridge-100/90">
                      <span class="text-ember-200">{row.id}</span> · {row.name}
                    </span>
                    <span class="font-mono text-xs text-bridge-100/60">{row.val}</span>
                  </div>
                  <div class="h-1.5 rounded-full bg-bridge-600/50 overflow-hidden">
                    <div class="h-full bg-gradient-to-r from-ember-500 to-ember-400 rounded-full" style={`width: ${row.share}%`}></div>
                  </div>
                </li>
              ))}
            </ul>
            <p class="mt-5 pt-4 border-t border-bridge-500/30 font-mono text-[10px] uppercase tracking-[0.18em] text-bridge-200/60">
              Values placeholder · live numbers from v0.5
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Budget transparency -->
  <section class="border-b border-bridge-100/40">
    <div class="container-page py-20 sm:py-24">
      <div class="grid gap-12 lg:grid-cols-12 lg:items-end mb-12">
        <div class="lg:col-span-7">
          <p class="eyebrow mb-4">Budget transparency</p>
          <h2 class="font-display text-3xl sm:text-4xl font-semibold tracking-snug text-ink-900 text-balance">
            Where the money goes.
          </h2>
          <p class="mt-6 text-lg text-ink-600 leading-relaxed text-pretty max-w-prose">
            The $50,000 scenario, split three ways. Engagement is the largest line because the work
            is fundamentally about people in rooms. Platform and AI are the smallest defensible
            number. The contingency is real — not aspirational.
          </p>
        </div>
        <div class="lg:col-span-5 lg:text-right">
          <div class="inline-flex flex-col items-start lg:items-end rounded-xl border border-bridge-100/60 bg-cream-50 p-5 shadow-card">
            <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-bridge-600">v0.0 scenario · 12 months</p>
            <p class="mt-2 font-display text-3xl font-semibold text-ink-900">$50,000</p>
            <p class="font-mono text-xs text-ink-500 mt-1">$25k floor also planned</p>
          </div>
        </div>
      </div>

      <!-- Stacked bar -->
      <div class="rounded-2xl border border-bridge-100/60 bg-cream-50 p-2 shadow-card overflow-hidden">
        <div class="flex h-12 w-full rounded-lg overflow-hidden">
          {tranche.map((t) => (
            <div
              class:list={[t.barClass, 'flex items-center justify-center text-cream-50 font-mono text-xs font-medium transition-all']}
              style={`width: ${t.pct}%`}
              title={`${t.label} · ${t.pct}%`}
            >
              {t.pct}%
            </div>
          ))}
        </div>
      </div>

      <!-- Tranche rows -->
      <dl class="mt-8 grid gap-5 sm:grid-cols-3">
        {tranche.map((t, i) => (
          <div class="rounded-xl border border-bridge-100/60 bg-cream-50 p-5 shadow-card">
            <div class="flex items-baseline gap-3 mb-3">
              <span class={`inline-block h-3 w-3 rounded-sm ${t.barClass}`}></span>
              <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-bridge-600">Tranche {i + 1}</span>
            </div>
            <dt class="font-display text-lg font-semibold text-ink-900 tracking-snug">{t.label}</dt>
            <p class="mt-1 font-mono text-xs text-bridge-600">{t.usd}</p>
            <dd class="mt-3 text-sm text-ink-600 leading-relaxed text-pretty">{t.tone}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- Roadmap -->
  <section>
    <div class="container-wide py-20 sm:py-24">
      <div class="mb-12 max-w-readable">
        <p class="eyebrow mb-4">Roadmap</p>
        <h2 class="font-display text-3xl sm:text-4xl font-semibold tracking-snug text-ink-900 text-balance">
          Release train.
        </h2>
        <p class="mt-6 text-lg text-ink-600 leading-relaxed text-pretty">
          Six releases. Each one ships a real artefact a funder or ministry can read.
          v0.0 is what you are looking at now.
        </p>
      </div>

      <!-- Train -->
      <div class="relative overflow-x-auto pb-4">
        <!-- Connecting line -->
        <div class="absolute top-[3.25rem] left-0 right-0 h-px bg-gradient-to-r from-bridge-200 via-bridge-300 to-bridge-100"></div>

        <ol class="relative flex gap-5 min-w-max">
          {releases.map((rel) => (
            <li
              class:list={[
                'relative w-72 flex-none rounded-2xl border bg-cream-50 p-6 shadow-card transition',
                rel.current
                  ? 'border-ember-500 ring-2 ring-ember-500/20 shadow-lift'
                  : 'border-bridge-100/60',
              ]}
            >
              <!-- Anchor dot on the line -->
              <span
                class:list={[
                  'absolute -top-0 left-6 h-3.5 w-3.5 rounded-full ring-4 ring-cream-50',
                  rel.current ? 'bg-ember-500' : 'bg-bridge-300',
                ]}
                style="top: -1.5rem"
              ></span>

              <div class="flex items-baseline justify-between mb-3">
                <p
                  class:list={[
                    'font-mono text-sm font-semibold tracking-wider',
                    rel.current ? 'text-ember-600' : 'text-bridge-600',
                  ]}
                >
                  {rel.version}
                </p>
                <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-ink-400">{rel.ship}</p>
              </div>
              <p class="font-display text-lg font-semibold text-ink-900 tracking-snug">{rel.headline}</p>

              {rel.current && (
                <span class="mt-2 inline-flex items-center gap-1.5 rounded-full bg-ember-500 px-2 py-0.5 font-mono text-[9px] uppercase tracking-[0.18em] text-cream-50">
                  <span class="h-1 w-1 rounded-full bg-cream-50 animate-pulse"></span>
                  Current
                </span>
              )}

              <ul class="mt-5 space-y-1.5 text-sm text-ink-600">
                {rel.deliverables.map((dlv) => (
                  <li class="flex gap-2 text-pretty leading-snug">
                    <span class="text-bridge-400 mt-0.5">→</span>
                    <span>{dlv}</span>
                  </li>
                ))}
              </ul>
            </li>
          ))}
        </ol>
      </div>

      <p class="mt-8 font-mono text-xs text-ink-400">
        Plan updates · committed quarterly via PR · last updated when this page was deployed.
      </p>
    </div>
  </section>

</Base>
