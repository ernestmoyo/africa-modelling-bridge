---
import Base from '@/layouts/Base.astro';

const ways = [
  {
    name: 'Back the movement',
    line: 'The convening core — the engine that makes everything else possible.',
    bullets: [
      'Bringing ministries and modellers into the same room',
      'Country coordination and facilitation',
      'Framing the modelling questions each country owns',
      'Methods support and supervision for researchers',
    ],
    fit: 'Capacity-strengthening and research-for-development funders.',
    accent: 'bridge',
  },
  {
    name: 'Back a country',
    line: 'A full year of the cadence in a single country.',
    bullets: [
      'Dialogue and discovery sessions',
      'A portfolio of country-led modelling questions',
      'Researchers placed and supported end-to-end',
      'Outputs the ministry can use and cite',
    ],
    fit: 'Foundations and partners with a country or regional focus.',
    accent: 'ember',
  },
  {
    name: 'Back a question',
    line: 'A single modelling question, from framing to finished output.',
    bullets: [
      'One researcher, one supervisor, one decision',
      'A feasible timeline and a clear budget',
      'A real answer for a real programme choice',
      'A visible result you can point to',
    ],
    fit: 'Individual donors and mission-aligned philanthropy.',
    accent: 'bridge',
  },
];
---

<Base
  title="Get involved"
  description="Support African governments to target scarce health resources with evidence and to build the case for funding on models they own. Back the movement, a country, or a single modelling question."
>
  <!-- ───────────────────────── Hero ───────────────────────── -->
  <section class="relative overflow-hidden border-b border-bridge-100/60">
    <div class="absolute inset-0 -z-10 opacity-[0.5]" aria-hidden="true">
      <svg viewBox="0 0 1200 400" preserveAspectRatio="xMidYMid slice" class="h-full w-full">
        <defs>
          <linearGradient id="funderGrad" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="#fadcc1" stop-opacity="0.0" />
            <stop offset="50%" stop-color="#f4b88e" stop-opacity="0.6" />
            <stop offset="100%" stop-color="#fadcc1" stop-opacity="0.0" />
          </linearGradient>
        </defs>
        <g stroke="#c1ddda" stroke-width="1" fill="none">
          <path d="M0,300 C200,240 380,280 600,240 C820,200 980,280 1200,240" />
          <path d="M0,340 C200,280 380,320 600,280 C820,240 980,320 1200,280" />
        </g>
        <path d="M 180,260 Q 600,40 1020,260" fill="none" stroke="url(#funderGrad)" stroke-width="2"/>
      </svg>
    </div>
    <div class="grain-overlay opacity-[0.2]"></div>

    <div class="container-page relative pt-20 pb-16 sm:pt-24 sm:pb-20">
      <p class="eyebrow flex items-center gap-3">
        <span class="inline-block h-px w-8 bg-bridge-300"></span>
        Get involved
      </p>
      <h1 class="mt-6 max-w-4xl font-display text-balance text-4xl font-light leading-[1.05] tracking-tightest text-ink-900 sm:text-5xl lg:text-6xl">
        Back a movement
        <br class="hidden sm:inline" />
        that makes modelling
        <span class="italic text-ember-600">count.</span>
      </h1>
      <p class="mt-8 max-w-2xl text-lg leading-relaxed text-ink-600 text-pretty">
        Support African governments to target scarce resources with evidence — and to build the case
        for funding on models they own. Whether you are a funder, a ministry, a university or a
        modeller, there is a way in.
      </p>

      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="#ways"
          class="inline-flex items-center gap-2 rounded-md bg-ember-500 px-5 py-3 text-sm font-medium text-cream-50 shadow-card transition hover:-translate-y-px hover:bg-ember-600"
        >
          Ways to support
          <svg viewBox="0 0 20 20" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 4v12m0 0l-4-4m4 4l4-4" stroke-linecap="round" stroke-linejoin="round" /></svg>
        </a>
        <a
          href="#contact"
          class="inline-flex items-center gap-2 rounded-md border border-bridge-200 bg-cream-50 px-5 py-3 text-sm font-medium text-bridge-700 transition hover:border-bridge-500 hover:bg-bridge-50"
        >
          Start a conversation
        </a>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── Ways to support ───────────────────────── -->
  <section id="ways" class="border-b border-bridge-100/60 bg-cream-100/40">
    <div class="container-page py-16 sm:py-20">
      <div class="max-w-3xl">
        <p class="eyebrow">Ways to support</p>
        <h2 class="mt-4 font-display text-3xl font-light leading-tight tracking-snug text-ink-900 sm:text-4xl text-balance">
          Three ways in. <span class="italic text-bridge-600">One movement.</span>
        </h2>
        <p class="mt-5 text-lg leading-relaxed text-ink-600 text-pretty">
          Support can be scoped to the whole movement, a single country, or a single question.
          Each can be backed on its own or in combination.
        </p>
      </div>

      <div class="mt-12 grid gap-6 lg:grid-cols-3">
        {ways.map((t) => (
          <article class="flex flex-col rounded-2xl border border-bridge-100/60 bg-cream-50 p-7 shadow-card">
            <h3 class="font-display text-2xl font-medium leading-tight text-ink-900">{t.name}</h3>
            <p class="mt-2 text-sm text-ink-600">{t.line}</p>

            <ul class="mt-6 space-y-2 text-sm text-ink-700">
              {t.bullets.map((b) => (
                <li class="flex items-start gap-2">
                  <span class={`mt-1.5 inline-block h-1 w-1 shrink-0 rounded-full ${t.accent === 'ember' ? 'bg-ember-500' : 'bg-bridge-500'}`}></span>
                  {b}
                </li>
              ))}
            </ul>

            <div class="mt-6 border-t border-bridge-100/70 pt-5">
              <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-bridge-600">Good fit for</p>
              <p class="mt-2 text-xs leading-relaxed text-ink-600">{t.fit}</p>
            </div>

            <a
              href="#contact"
              class={`mt-7 inline-flex w-full items-center justify-center gap-2 rounded-md px-4 py-2.5 text-sm font-medium transition hover:-translate-y-px ${
                t.accent === 'ember'
                  ? 'bg-ember-500 text-cream-50 shadow-card hover:bg-ember-600'
                  : 'bg-bridge-600 text-cream-50 shadow-card hover:bg-bridge-700'
              }`}
            >
              Talk to us
              <svg viewBox="0 0 20 20" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke-linecap="round" stroke-linejoin="round" /></svg>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ───────────────────────── What support enables ───────────────────────── -->
  <section class="border-b border-bridge-100/60">
    <div class="container-page py-16 sm:py-20">
      <div class="max-w-3xl">
        <p class="eyebrow">What support enables</p>
        <h2 class="mt-4 font-display text-3xl font-light leading-tight tracking-snug text-ink-900 sm:text-4xl text-balance">
          Start lean, or go wide.
        </h2>
        <p class="mt-5 max-w-2xl text-base leading-relaxed text-ink-600">
          A first year can be run lean to prove the model in one country, or scaled to run the full
          cadence across the pilot countries. Indicative figures — final budgets are shaped with the
          funder.
        </p>
      </div>

      <div class="mt-12 grid gap-6 lg:grid-cols-2">
        <article class="flex flex-col rounded-2xl border border-bridge-100/60 bg-cream-50 p-8 shadow-card">
          <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-bridge-600">Lean start</p>
          <p class="mt-3 font-display text-5xl font-light tracking-tightest text-ink-900">~ USD 25k</p>
          <p class="mt-3 text-sm text-ink-600">Prove the movement end-to-end in one country.</p>
          <ul class="mt-7 space-y-3 border-t border-bridge-100/70 pt-5 text-sm text-ink-700">
            <li class="flex gap-3"><span class="font-mono text-bridge-500">·</span>The full cadence run once, in a single country</li>
            <li class="flex gap-3"><span class="font-mono text-bridge-500">·</span>A first set of ministry questions framed and placed</li>
            <li class="flex gap-3"><span class="font-mono text-bridge-500">·</span>Researchers supported through to a usable output</li>
            <li class="flex gap-3"><span class="font-mono text-bridge-500">·</span>A clean evidence base for a year-two scale-up</li>
          </ul>
        </article>

        <article class="flex flex-col rounded-2xl border border-ember-200 bg-ember-50 p-8 shadow-lift">
          <div class="flex items-baseline justify-between">
            <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-ember-700">Full year</p>
            <p class="font-display text-xs uppercase tracking-[0.18em] text-ember-600">Recommended</p>
          </div>
          <p class="mt-3 font-display text-5xl font-light tracking-tightest text-ink-900">~ USD 50k</p>
          <p class="mt-3 text-sm text-ink-700">Run the full cadence across the pilot countries.</p>
          <ul class="mt-7 space-y-3 border-t border-ember-200 pt-5 text-sm text-ink-700">
            <li class="flex gap-3"><span class="font-mono text-ember-600">·</span>Everything in the lean start, across more countries</li>
            <li class="flex gap-3"><span class="font-mono text-ember-600">·</span>Dialogue and discovery in each pilot country</li>
            <li class="flex gap-3"><span class="font-mono text-ember-600">·</span>A broader portfolio of funded questions</li>
            <li class="flex gap-3"><span class="font-mono text-ember-600">·</span>A working presence in Francophone Africa</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── Contact ───────────────────────── -->
  <section id="contact" class="bg-bridge-700 text-cream-50">
    <div class="container-page py-20 sm:py-24">
      <div class="grid items-center gap-12 lg:grid-cols-12">
        <div class="lg:col-span-7">
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-ember-200">Get in touch</p>
          <h2 class="mt-4 font-display text-4xl font-light leading-tight tracking-snug text-cream-50 sm:text-5xl text-balance">
            One conversation
            <span class="italic text-ember-200">moves a project.</span>
          </h2>
          <p class="mt-6 max-w-xl text-lg leading-relaxed text-cream-100/85 text-pretty">
            Write to Ernest Moyo, founder and lead modeller. For senior-adviser introductions or
            funder-network routing, mention Lesley-Anne Long.
          </p>
        </div>

        <div class="lg:col-span-5">
          <div class="rounded-2xl border border-cream-50/20 bg-bridge-800/50 p-7 backdrop-blur">
            <div>
              <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-cream-100/60">Founder &amp; Lead Modeller</p>
              <p class="mt-2 font-display text-2xl font-light text-cream-50">Ernest Moyo</p>
              <p class="mt-1 text-sm text-cream-100/70">Epidemiologist &amp; Health-Systems Modeller</p>
            </div>

            <a
              href="mailto:ernest@africamodellingbridge.org?subject=Africa%20Modelling%20Bridge"
              class="mt-6 inline-flex w-full items-center justify-center gap-2 rounded-md bg-ember-500 px-5 py-3 text-sm font-medium text-cream-50 shadow-lift transition hover:-translate-y-px hover:bg-ember-600"
            >
              Start a conversation
              <svg viewBox="0 0 20 20" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke-linecap="round" stroke-linejoin="round" /></svg>
            </a>

            <div class="mt-6 border-t border-cream-50/15 pt-5">
              <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-cream-100/60">Senior adviser · introductions</p>
              <p class="mt-2 text-sm text-cream-100/85">Lesley-Anne Long · Wonderfuture · Lunch for Democracy</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
